# ──────────────────────────────────────────────
# Ecuacity — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ─── Authentication (Better Auth) ────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Change for production: https://tudominio.com
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────
# Local (Docker): postgresql://postgres:postgres@localhost:5432/ecuacity
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecuacity

# ─── Email (choose one provider) ─────────────────────
# Options: "resend" | "smtp"
EMAIL_PROVIDER=resend
EMAIL_FROM=Ecuacity <noreply@ecuacity.com>
# Get your key at https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=

# SMTP (only if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_IGNORE_TLS=false
# SMTP_USER=
# SMTP_PASS=

# ─── Optional: Route overrides ───────────────────────
# Comma-separated lists of path prefixes (defaults shown below)
# NEXT_PUBLIC_AUTH_PAGES=/sign-in,/sign-up
# ADMIN_PAGES=/dashboard
# USER_PAGES=/students
# PREMIUM_PAGES=/students/categorias

# ─── Payphone (payment gateway) ───────────────────────
# Get these from https://appdeveloper.payphonetodoesposible.com
# Toggle slider to Prueba for sandbox testing
# PAYPHONE_ENDPOINT=https://pay.payphonetodoesposible.com
# PAYPHONE_TOKEN=
# PAYPHONE_STORE_ID=
# PAYPHONE_RESPONSE_URL=https://ecuacity.com/api/payphone/confirm
# PAYPHONE_CANCELLATION_URL=https://ecuacity.com/students/upgrade

# ─── Subscription defaults ────────────────────────────
# PREMIUM_PRICE_CENTS=1000
# PREMIUM_DURATION_DAYS=30

# ─── Optional: Session timeout ───────────────────────
# Idle timeout in ms (default: 1 hour / 3,600,000)
# Session check interval in ms (default: 1 min / 60,000)
# NEXT_PUBLIC_SESSION_TIMEOUT_MS=3600000
# NEXT_PUBLIC_SESSION_CHECK_INTERVAL_MS=60000
